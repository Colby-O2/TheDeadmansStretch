{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "774b7ee27dfb4c94947275973a9f3ecc",
    "m_Title": "NOTE",
    "m_Content": "In comparsion to the main PSX PBR the texture resolution needs to be set much higher to achieve the same effect (approximately 512x higher). \n\nFor now I just multiplied the inputted Texture Resolution by 512. However this factor may need to be changed if terrian setting are changed from the default.\n\nI think this has to do with internal tiling/sampling of the texture in the terrian system but can't figure out how to fix this as of now. ",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1971.0,
        "y": 1385.0,
        "width": 187.0,
        "height": 309.0
    },
    "m_Group": {
        "m_Id": "acc849cb1f2440a18f70e5dcedc95de7"
    }
}

